{
  "name": "@paragraph-com/sdk",
  "version": "3.0.0",
  "description": "TypeScript SDK for Paragraph API",
  "repository": {
    "url": "git+https://github.com/paragraph-xyz/paragraph-sdk-js.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "import": "./dist/zod.mjs",
      "require": "./dist/zod.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "generate": "orval --config orval.config.ts && typedoc",
    "prepublishOnly": "yarn generate && yarn build",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "dependencies": {},
  "peerDependencies": {
    "@whetstone-research/doppler-sdk": "^0.0.1-alpha.62",
    "doppler-router": "^1.0.15",
    "viem": "^2.40.3",
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@whetstone-research/doppler-sdk": {
      "optional": true
    },
    "doppler-router": {
      "optional": true
    },
    "viem": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@whetstone-research/doppler-sdk": "^0.0.1-alpha.62",
    "doppler-router": "^1.0.15",
    "orval": "^7.11.2",
    "tsup": "^8.3.5",
    "typedoc": "^0.28.12",
    "typedoc-plugin-markdown": "^4.8.1",
    "typescript": "^5.0.0",
    "zod": "^3.24.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "yarn@3.4.1"
}
